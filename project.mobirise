                  "display": "none"
                }
              },
              "&.navbar-short": {
                "@media (max-width: 1200px)": {
                  "min-height": "60px"
                },
                "@media (min-width: 1200px)": {
                  "min-height": "60px"
                },
                ".navbar-brand": {
                  "margin-top": "-7rem",
                  "height": "0%",
                  "padding": "0"
                },
                ".social-block": {
