  "pages": {
    "about.html": {
      "settings": {
        "title": "About | Sage Delio Fine Art",
        "order": 2,
        "header_custom": "<meta name=\"keywords\" content=\"Sage Delio, about Sage Delio, Sage Delio biography\">",
