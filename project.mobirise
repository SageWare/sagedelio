            },
            "@media (max-width: 991px)": {
              ".social-media": {
                "-webkit-justify-content": "center",
                "justify-content": "center",
                "padding-right": "15px"
              },
              ".logo-section": {
                "-webkit-justify-content": "center",
                "justify-content": "center",
